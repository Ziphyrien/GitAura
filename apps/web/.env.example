# Better Auth base config.
BETTER_AUTH_SECRET=replace-with-a-32-plus-character-secret
BETTER_AUTH_URL=http://localhost:3000
VITE_BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# GitHub OAuth app credentials.
GITHUB_CLIENT_ID=your_github_app_client_id
GITHUB_CLIENT_SECRET=your_github_app_client_secret

# Optional server-side token used by the public GitHub proxy at /api/github/*.
# Leave disabled locally unless you want signed-out public metadata reads to proxy through the server.
GITHUB_PROXY_TOKEN=github_pat_your_proxy_token_here
VITE_GITHUB_PROXY_ENABLED=false

# Autumn billing secret used by the Autumn SDK routes and server-side metering.
AUTUMN_SECRET_KEY=am_sk_test_your_autumn_secret_key_here

# Dexie Cloud sync + public share configuration.
# Create or connect your cloud database first, then keep dexie-cloud.json and dexie-cloud.key
# out of git. Add them to .gitignore if you create them locally.
# Example setup:
#   npx dexie-cloud create
#   npx dexie-cloud whitelist http://localhost:3001
#   npx dexie-cloud whitelist https://gitinspect.com
DEXIE_CLOUD_DB_URL=https://your-db.dexie.cloud
DEXIE_CLOUD_CLIENT_ID=your_dexie_cloud_client_id
DEXIE_CLOUD_CLIENT_SECRET=your_dexie_cloud_client_secret
VITE_DEXIE_CLOUD_DB_URL=https://your-db.dexie.cloud

# API key injected server-side for "OpenCode Free" tier requests.
# The TanStack Start server route at /api/proxy reads this and attaches it to
# outgoing requests so the key never appears in the client bundle.
FIREWORKS_API_KEY=fw-your-fireworks-api-key-here

# Optional feedback-to-GitHub integration for /api/feedback.
FEEDBACK_GITHUB_TOKEN=github_pat_your_feedback_token_here
FEEDBACK_GITHUB_OWNER=your-org-or-user
FEEDBACK_GITHUB_REPO=your-main-app-repo
